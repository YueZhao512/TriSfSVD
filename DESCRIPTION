Package: TriSfSVD
Type: Package
Title: Functional SVD Based Tri-Clustering
Version: 0.1.0
Authors@R: c(
    person(given = "Yue", family = "Zhao", email = "zhao0646@umn.edu", role = c("aut", "cre")),
    person(given = "Thierry", family = "Chekouo", email = "tchekouo@umn.edu", role = "aut"),
